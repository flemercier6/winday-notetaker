# Edge Function secrets for Winday Notetaker.
#
# These are the ONLY place the third-party API keys live. They are set on the
# Supabase project (server-side) and are never shipped to the macOS app.
#
# Set them with the Supabase CLI:
#   supabase secrets set --env-file supabase/.env --project-ref jruoxnwhmgmajbzsjsjw
# or one by one in the dashboard: Project Settings → Edge Functions → Secrets.
#
# Copy this file to supabase/.env (gitignored) and fill in real values.

DEEPGRAM_API_KEY=your_deepgram_key_here
GEMINI_API_KEY=your_google_ai_studio_key_here
NOTION_TOKEN=your_notion_internal_integration_token_here

# Note: SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are
# injected automatically into every Edge Function — do NOT set them here.
